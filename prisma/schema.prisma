// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model VisitorSession {
  id                 String              @id
  userAccountId      String?
  userAccount        UserAccount?        @relation(fields: [userAccountId], references: [id], onDelete: SetNull)
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  lastfmConnection   LastfmConnection?
  analysisRuns       AnalysisRun[]
  recommendationRuns RecommendationRun[]
  agentRuns          AgentRun[]
}

model UserAccount {
  id                 String              @id @default(cuid())
  lastfmUsername     String              @unique
  lastfmSessionKey   String?
  displayName        String?
  avatarUrl          String?
  lastLoginAt        DateTime?
  loginCount         Int                 @default(0)
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  authSessions       AuthSession[]
  visitorSessions    VisitorSession[]
  analysisRuns       AnalysisRun[]
  recommendationRuns RecommendationRun[]
  agentRuns          AgentRun[]
  savedArtists       SavedArtist[]
  weeklyListeningState UserWeeklyListeningState?
  weeklyArtistPlaycounts UserWeeklyArtistPlaycount[]
  knownArtistRollup     UserKnownArtistRollup[]
  weeklyIngestedWeeks   UserWeeklyIngestedWeek[]
  weeklyBackfillJob     UserWeeklyBackfillJob?
  recentTailState       UserRecentTailState?
  recentTailArtistCounts UserRecentTailArtistCount[]
  dataPullLogs          UserDataPullLog[]
}

model AuthSession {
  id             String      @id @default(cuid())
  userAccountId  String
  userAccount    UserAccount @relation(fields: [userAccountId], references: [id], onDelete: Cascade)
  tokenHash      String      @unique
  userAgent      String?
  ipAddress      String?
  expiresAt      DateTime
  lastActiveAt   DateTime    @default(now())
  createdAt      DateTime    @default(now())

  @@index([userAccountId])
  @@index([expiresAt])
}

model LastfmConnection {
  id                 String         @id @default(cuid())
  visitorSessionId   String         @unique
  visitorSession     VisitorSession @relation(fields: [visitorSessionId], references: [id], onDelete: Cascade)
  status             String         @default("disconnected")
  lastfmUsername     String?
  authErrorCode      String?
  lastVerifiedAt     DateTime?
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt
}

model AnalysisRun {
  id                 String         @id @default(cuid())
  visitorSessionId   String
  visitorSession     VisitorSession @relation(fields: [visitorSessionId], references: [id], onDelete: Cascade)
  userAccountId      String?
  userAccount        UserAccount?   @relation(fields: [userAccountId], references: [id], onDelete: SetNull)
  targetLastfmUsername String?
  rangeStart         Int
  rangeEnd           Int
  sourceVersion      String
  artistsJson        Json
  tracksJson         Json
  heardArtistsJson   Json
  lanesJson          Json
  createdAt          DateTime       @default(now())
  recommendationRuns RecommendationRun[]

  @@index([userAccountId, createdAt])
  @@index([targetLastfmUsername, createdAt])
}

model RecommendationRun {
  id               String         @id @default(cuid())
  visitorSessionId String
  visitorSession   VisitorSession @relation(fields: [visitorSessionId], references: [id], onDelete: Cascade)
  userAccountId    String?
  userAccount      UserAccount?   @relation(fields: [userAccountId], references: [id], onDelete: SetNull)
  targetLastfmUsername String?
  analysisRunId    String
  analysisRun      AnalysisRun    @relation(fields: [analysisRunId], references: [id], onDelete: Cascade)
  selectedLane     String
  newOnly          Boolean        @default(false)
  resultsJson      Json
  createdAt        DateTime       @default(now())

  @@index([analysisRunId, createdAt])
}

model AgentRun {
  id               String         @id @default(cuid())
  visitorSessionId String
  visitorSession   VisitorSession @relation(fields: [visitorSessionId], references: [id], onDelete: Cascade)
  userAccountId    String?
  userAccount      UserAccount?   @relation(fields: [userAccountId], references: [id], onDelete: SetNull)
  targetLastfmUsername String?
  mode             String
  status           String         @default("queued")
  requestJson      Json
  resultJson       Json?
  errorMessage     String?
  toolCallsUsed    Int            @default(0)
  maxToolCalls     Int            @default(10)
  timeoutMs        Int
  terminationReason String?
  startedAt        DateTime?
  completedAt      DateTime?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  events           AgentRunEvent[]

  @@index([userAccountId, createdAt])
}

model AgentRunEvent {
  id        String   @id @default(cuid())
  runId     String
  run       AgentRun @relation(fields: [runId], references: [id], onDelete: Cascade)
  seq       Int
  type      String
  payloadJson Json
  createdAt DateTime @default(now())

  @@index([runId, seq])
}

model LastfmApiCache {
  id             String   @id @default(cuid())
  cacheKey       String   @unique
  scope          String
  method         String
  paramsJson     Json
  dataJson       Json
  expiresAt      DateTime
  hitCount       Int      @default(0)
  lastAccessedAt DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([scope, method])
  @@index([expiresAt])
}

model SavedArtist {
  id                         String      @id @default(cuid())
  userAccountId              String
  userAccount                UserAccount @relation(fields: [userAccountId], references: [id], onDelete: Cascade)
  artistName                 String
  normalizedName             String
  savedFromRecommendationRunId String?
  savedFromAnalysisRunId     String?
  savedFromLaneId            String?
  savedFromTargetUsername    String?
  knownPlaycountAtSave       Int?
  knownArtistAtSave          Boolean?
  recommendationContextJson  Json?
  savedAt                    DateTime    @default(now())
  updatedAt                  DateTime    @updatedAt

  @@unique([userAccountId, normalizedName])
  @@index([userAccountId, savedAt])
}

model UserWeeklyListeningState {
  id                    String      @id @default(cuid())
  userAccountId         String      @unique
  userAccount           UserAccount @relation(fields: [userAccountId], references: [id], onDelete: Cascade)
  lastfmUsername        String
  status                String      @default("idle")
  weeksDiscovered       Int         @default(0)
  weeksProcessed        Int         @default(0)
  newestWeekStart       Int?
  oldestWeekStart       Int?
  lastProcessedWeekStart Int?
  lastProcessedWeekEnd  Int?
  recentYearReadyAt     DateTime?
  fullHistoryReadyAt    DateTime?
  lastAttemptAt         DateTime?
  lastSuccessAt         DateTime?
  lastErrorCode         String?
  lastErrorMessage      String?
  createdAt             DateTime    @default(now())
  updatedAt             DateTime    @updatedAt
}

model UserWeeklyArtistPlaycount {
  id             String      @id @default(cuid())
  userAccountId  String
  userAccount    UserAccount @relation(fields: [userAccountId], references: [id], onDelete: Cascade)
  weekStart      Int
  weekEnd        Int
  artistName     String
  normalizedName String
  playcount      Int
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  @@unique([userAccountId, weekStart, weekEnd, normalizedName])
  @@index([userAccountId, weekStart])
  @@index([userAccountId, normalizedName])
}

model UserWeeklyIngestedWeek {
  id               String      @id @default(cuid())
  userAccountId    String
  userAccount      UserAccount @relation(fields: [userAccountId], references: [id], onDelete: Cascade)
  weekStart        Int
  weekEnd          Int
  status           String      @default("done")
  artistCount      Int         @default(0)
  attemptCount     Int         @default(1)
  lastAttemptAt    DateTime    @default(now())
  lastErrorMessage String?
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt

  @@unique([userAccountId, weekStart, weekEnd])
  @@index([userAccountId, status])
}

model UserWeeklyBackfillJob {
  id                  String      @id @default(cuid())
  userAccountId       String      @unique
  userAccount         UserAccount @relation(fields: [userAccountId], references: [id], onDelete: Cascade)
  lastfmUsername      String
  status              String      @default("queued")
  priority            Int         @default(100)
  nextRunAt           DateTime    @default(now())
  lockToken           String?
  lockExpiresAt       DateTime?
  lastHeartbeatAt     DateTime?
  attemptCount        Int         @default(0)
  consecutiveFailures Int         @default(0)
  lastErrorCode       String?
  lastErrorMessage    String?
  createdAt           DateTime    @default(now())
  updatedAt           DateTime    @updatedAt

  @@index([status, nextRunAt])
  @@index([lockExpiresAt])
}

model UserKnownArtistRollup {
  id             String      @id @default(cuid())
  userAccountId  String
  userAccount    UserAccount @relation(fields: [userAccountId], references: [id], onDelete: Cascade)
  artistName     String
  normalizedName String
  playcount      Int         @default(0)
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  @@unique([userAccountId, normalizedName])
  @@index([userAccountId, playcount])
}

model UserRecentTailState {
  id                 String      @id @default(cuid())
  userAccountId      String      @unique
  userAccount        UserAccount @relation(fields: [userAccountId], references: [id], onDelete: Cascade)
  lastfmUsername     String
  status             String      @default("idle")
  latestWeeklyBoundary Int?
  tailFrom           Int?
  tailTo             Int?
  artistCount        Int         @default(0)
  lastPullStartedAt  DateTime?
  lastPullCompletedAt DateTime?
  lastErrorMessage   String?
  createdAt          DateTime    @default(now())
  updatedAt          DateTime    @updatedAt
}

model UserRecentTailArtistCount {
  id             String      @id @default(cuid())
  userAccountId  String
  userAccount    UserAccount @relation(fields: [userAccountId], references: [id], onDelete: Cascade)
  artistName     String
  normalizedName String
  playcount      Int
  tailFrom       Int
  tailTo         Int
  pulledAt       DateTime    @default(now())
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  @@unique([userAccountId, normalizedName])
  @@index([userAccountId, playcount])
}

model UserDataPullLog {
  id            String      @id @default(cuid())
  userAccountId String
  userAccount   UserAccount @relation(fields: [userAccountId], references: [id], onDelete: Cascade)
  source        String
  status        String      @default("success")
  windowFrom    Int?
  windowTo      Int?
  recordCount   Int?
  errorMessage  String?
  pulledAt      DateTime    @default(now())
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@index([userAccountId, pulledAt])
  @@index([userAccountId, source, pulledAt])
}
