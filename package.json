{
  "name": "web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "preview": "opennextjs-cloudflare build && opennextjs-cloudflare preview",
    "deploy": "opennextjs-cloudflare build && opennextjs-cloudflare deploy",
    "upload": "opennextjs-cloudflare build && opennextjs-cloudflare upload",
    "cf-typegen": "wrangler types --env-interface CloudflareEnv cloudflare-env.d.ts",
    "lint": "eslint",
    "bench:llm": "node scripts/llm-latency-benchmark.mjs",
    "ops:discovery-smoke": "node scripts/discovery-run-smoke-check.mjs",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:push": "prisma db push",
    "db:d1:migrations:create": "wrangler d1 migrations create playhead-db",
    "db:d1:migrations:apply:local": "wrangler d1 migrations apply playhead-db --local",
    "db:d1:migrations:apply:remote": "wrangler d1 migrations apply playhead-db --remote",
    "db:d1:diff": "prisma migrate diff --from-empty --to-schema-datamodel prisma/schema.prisma --script --output",
    "db:d1:execute:local": "wrangler d1 execute playhead-db --local --file",
    "db:d1:execute:remote": "wrangler d1 execute playhead-db --remote --file",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@opennextjs/cloudflare": "^1.13.1",
    "@prisma/adapter-d1": "^6.14.0",
    "@prisma/client": "^6.14.0",
    "next": "16.1.6",
    "openai": "^6.27.0",
    "prisma": "^6.14.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.1.1",
    "wrangler": "^4.39.0"
  }
}
